# ---- Database ----
# Leave DATABASE_URL UNSET to use the zero-setup embedded database (PGlite).
# Set it to run against a real PostgreSQL server (e.g. Docker):
# DATABASE_URL="postgresql://smartsme:smartsme@localhost:5432/smartsme"

# ---- Auth ----
# Any long random string, 32+ characters. Used to sign session cookies.
# Required in production; in development a built-in dev secret is used if unset.
AUTH_SECRET="change-me-to-a-long-random-string-32-chars-min"

# ---- AI provider (optional) ----
# The Smart Input Engine is provider-agnostic. Without any key it uses a built-in
# heuristic parser (text only). Set ONE provider's key to upgrade natural-language
# parsing and image OCR. If several are set, the first below wins, or force one
# with AI_PROVIDER (anthropic | openai | groq | google).
# AI_PROVIDER=""

# -- Anthropic (Claude) --
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# -- Groq (fast, OpenAI-compatible; just set the key) --
# Default model is text-only. For image OCR, set GROQ_MODEL to a vision model
# (e.g. meta-llama/llama-4-scout-17b-16e-instruct).
GROQ_API_KEY=
GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# -- OpenAI, or ANY other OpenAI-compatible endpoint --
# Works with OpenAI, OpenRouter, Together, DeepSeek, a local server, etc.
# Point OPENAI_BASE_URL at the provider and set OPENAI_MODEL accordingly.
#   OpenRouter: OPENAI_BASE_URL="https://openrouter.ai/api/v1"
#   Local:      OPENAI_BASE_URL="http://localhost:11434/v1"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"

# -- Google Gemini --
GOOGLE_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
